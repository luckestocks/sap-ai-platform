# ─────────────────────────────────────────────────────────────────
# SAP AI Platform — Environment Variables Template
# Copy this to .env and fill in your real values.
# NEVER commit .env to GitHub — it is protected by .gitignore
# ─────────────────────────────────────────────────────────────────

# Google Gemini Flash (default LLM — free tier)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude Sonnet 4.6 (premium LLM — pay per use)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq Llama 3.1 70B (fallback LLM — free, 14,400 req/day)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Supabase (vector DB + PostgreSQL)
# Get from: https://app.supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# SAP Datasphere REST API (Tool 3 — Phase 3)
# Get from: BTP Trial → Datasphere → Security → OAuth Clients
DATASPHERE_API_URL=https://your-tenant.ds.cfapps.your-region.hana.ondemand.com
DATASPHERE_CLIENT_ID=your_datasphere_client_id
DATASPHERE_CLIENT_SECRET=your_datasphere_client_secret
DATASPHERE_SPACE_ID=your_datasphere_space_id

# App config
DEFAULT_LLM_PROVIDER=gemini
